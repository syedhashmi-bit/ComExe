# build artifacts
# .next is intentionally NOT ignored — we ship the prebuilt output.
# Cache and trace inside .next aren't needed at runtime, ignore them.
.next/cache
.next/trace
node_modules
npm-debug.log
tsconfig.tsbuildinfo

# version control
.git
.gitignore

# docker meta
Dockerfile
.dockerignore

