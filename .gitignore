# dependencies
node_modules/
.pnp
.pnp.js

# next.js
# .next/ is intentionally tracked — TrueNAS Docker can't build reliably
# (Next.js build worker SIGSEGVs non-deterministically on this host), so
# the build happens on the PC and the prebuilt artifacts are shipped via git.
# The cache and trace inside .next/ are not needed at runtime, so we still
# ignore them to keep commits small.
.next/cache/
.next/trace
out/

# claude code
.claude/

# local development / private notes
# CLAUDE.md, context.md, memory.md, skills.md are tracked because they document
# the project for future Claude Code sessions and are scrubbed of secrets.
Read-Prompt.txt
gh

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
